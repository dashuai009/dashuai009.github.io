---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MyPDFViewer from "../components/MyPDFViewer/MyPDFViewer";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead
      title="PBRT v4 中文翻译 PDF"
      description="PBRT v4 中文翻译项目 PDF 预览"
    />
    <style>
      main {
        max-width: 960px;
        margin: 0 auto;
        padding: 2rem 1rem;
      }
      #viewer {
        box-shadow: var(--box-shadow);
        margin-bottom: 1rem;
        text-align: center;
      }
      #controls {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1rem;
      }
      #controls button {
        padding: 0.5rem 1rem;
        background: var(--accent);
        color: #fff;
        border: none;
        border-radius: 4px;
        cursor: pointer;
      }
      #controls button:disabled {
        opacity: 0.5;
        cursor: default;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>PBRT v4 中文翻译 PDF</h1>
      <div id="viewer"></div>
      <div class="pbrt-actions">
        <a
          href="https://github.com/dashuai009/pbrt-v4-zh"
          target="_blank"
          rel="noopener">GitHub</a
        >
      </div>
      <MyPDFViewer
        input_file="https://github.com/dashuai009/pbrt-v4-zh/releases/download/v0.0.2/pbrt-v4-en-v0.0.2.pdf"
        client:only="react"
      />
      <div id="controls">
        <button id="prev">上一页</button>
        <span id="page-info">1 / ?</span>
        <button id="next">下一页</button>
      </div>
    </main>
    <Footer />
  </body>
</html>
